{
  "schema_version": 1,
  "campaign_id": "sun-temple-adventure",
  "storage_key": "english-game:sun-temple-adventure",
  "scene_id": "sun-temple-adventure-base-camp-table",
  "debug": { "enabled": true },
  "initial_state": {
    "facts": {
      "location.base_camp.discovered": true,
      "location.camp_supply_tent.discovered": true,
      "location.camp_edge.discovered": true
    },
    "inventory": [],
    "counters": {},
    "puzzles": {}
  },
  "puzzles": [
    {
      "id": "sun_temple_slice_01_complete",
      "title": "Place the Green Lens in the Sun Compass",
      "type": "adventure_milestone",
      "final": false,
      "requires": { "fact": "slice.green_lens_complete", "equals": true },
      "produces": ["sun_temple.slice_01.complete"]
    },
    {
      "id": "sun_temple_slice_02_complete",
      "title": "Place the Blue Lens in the Sun Compass",
      "type": "adventure_milestone",
      "final": true,
      "requires": { "fact": "slice.blue_lens_complete", "equals": true },
      "produces": ["sun_temple.slice_02.complete"]
    }
  ],
  "rules": [
    {
      "id": "inspect-sun-compass",
      "event": { "type": "hotspot.inspected", "target": "sun_compass" },
      "actions": [
        { "type": "fact.set", "fact": "compass.inspected", "value": true },
        { "type": "dialog.show", "speaker": "Mira", "text": "This is the Sun Compass. It has five empty spots.", "bg": "Това е Слънчевият компас. Има пет празни места." }
      ]
    },
    {
      "id": "take-torn-map",
      "once": true,
      "event": { "type": "item.taken", "target": "torn_map" },
      "actions": [
        { "type": "inventory.add", "item": "torn_map" },
        { "type": "fact.set", "fact": "item.torn_map.taken", "value": true },
        { "type": "fact.set", "fact": "map.ui_unlocked", "value": true },
        { "type": "ui.toast", "text": "The map is open." },
        { "type": "screen.refresh" }
      ]
    },
    {
      "id": "take-rope",
      "once": true,
      "event": { "type": "item.taken", "target": "rope" },
      "actions": [
        { "type": "inventory.add", "item": "rope" },
        { "type": "fact.set", "fact": "item.rope.taken", "value": true },
        { "type": "dialog.show", "speaker": "Alex", "text": "I have a rope.", "bg": "Имам въже." },
        { "type": "screen.refresh" }
      ]
    },
    {
      "id": "inspect-branch-first",
      "priority": 5,
      "once": true,
      "event": { "type": "hotspot.inspected", "target": "fallen_branch" },
      "stop_propagation": true,
      "actions": [
        { "type": "fact.set", "fact": "camp_edge.branch_inspected", "value": true },
        { "type": "dialog.show", "speaker": "Alex", "text": "There is a map piece under the branch.", "bg": "Има парче от карта под клона." }
      ]
    },
    {
      "id": "move-branch",
      "priority": 10,
      "once": true,
      "event": { "type": "hotspot.inspected", "target": "fallen_branch" },
      "condition": { "fact": "camp_edge.branch_inspected", "equals": true },
      "actions": [
        { "type": "fact.set", "fact": "camp_edge.branch_moved", "value": true },
        { "type": "dialog.show", "speaker": "Alex", "text": "The map piece is here.", "bg": "Парчето от карта е тук." },
        { "type": "screen.refresh" }
      ]
    },
    {
      "id": "take-map-piece",
      "once": true,
      "event": { "type": "item.taken", "target": "map_piece_01" },
      "condition": { "fact": "camp_edge.branch_moved", "equals": true },
      "actions": [
        { "type": "inventory.add", "item": "map_piece_01" },
        { "type": "fact.set", "fact": "item.map_piece_01.taken", "value": true },
        { "type": "dialog.show", "speaker": "Alex", "text": "I have a map piece.", "bg": "Имам парче от карта." },
        { "type": "screen.refresh" }
      ]
    },
    {
      "id": "combine-valley-map",
      "once": true,
      "event": { "type": "inventory.items_combined" },
      "condition": {
        "all": [
          { "event": "items.0", "equals": "map_piece_01" },
          { "event": "items.1", "equals": "torn_map" },
          { "inventory_contains": "torn_map" },
          { "inventory_contains": "map_piece_01" }
        ]
      },
      "actions": [
        { "type": "inventory.remove", "item": "torn_map" },
        { "type": "inventory.remove", "item": "map_piece_01" },
        { "type": "inventory.add", "item": "valley_map" },
        { "type": "fact.set", "fact": "map.valley_map_made", "value": true },
        { "type": "fact.set", "fact": "location.jungle_path.discovered", "value": true },
        { "type": "ui.toast", "text": "This is the map." },
        { "type": "screen.refresh" }
      ]
    },
    {
      "id": "inspect-path-marker",
      "event": { "type": "hotspot.inspected", "target": "path_marker" },
      "actions": [
        { "type": "fact.set", "fact": "jungle_path.marker_seen", "value": true },
        { "type": "dialog.show", "speaker": "Alex", "text": "The river path is here.", "bg": "Пътеката към реката е тук." }
      ]
    },
    {
      "id": "inspect-bridge-without-rope",
      "priority": 5,
      "event": { "type": "hotspot.inspected", "target": "broken_bridge" },
      "condition": { "not": { "fact": "bridge.repaired", "equals": true } },
      "actions": [
        { "type": "dialog.show", "speaker": "Alex", "text": "The bridge is not safe. I need a rope.", "bg": "Мостът не е безопасен. Трябва ми въже." }
      ]
    },
    {
      "id": "repair-bridge",
      "once": true,
      "event": { "type": "inventory.item_used_on_hotspot", "target": "broken_bridge" },
      "condition": {
        "all": [
          { "event": "item", "equals": "rope" },
          { "inventory_contains": "rope" }
        ]
      },
      "actions": [
        { "type": "inventory.remove", "item": "rope" },
        { "type": "fact.set", "fact": "bridge.repaired", "value": true },
        { "type": "fact.set", "fact": "location.broken_bridge.discovered", "value": true },
        { "type": "fact.set", "fact": "location.village_garden.discovered", "value": true },
        { "type": "dialog.show", "speaker": "Alex", "text": "The bridge is safe now.", "bg": "Мостът вече е безопасен." },
        { "type": "screen.refresh" }
      ]
    },
    {
      "id": "take-lost-basket",
      "once": true,
      "event": { "type": "item.taken", "target": "lost_basket" },
      "condition": { "fact": "bridge.repaired", "equals": true },
      "actions": [
        { "type": "inventory.add", "item": "lost_basket" },
        { "type": "fact.set", "fact": "item.lost_basket.taken", "value": true },
        { "type": "dialog.show", "speaker": "Alex", "text": "I have Lina's basket.", "bg": "Имам кошницата на Лина." },
        { "type": "screen.refresh" }
      ]
    },
    {
      "id": "talk-to-mira",
      "event": { "type": "npc.talked", "target": "mira" },
      "actions": [
        { "type": "dialog.show", "speaker": "Mira", "text": "The Sun Compass needs five lenses.", "bg": "Слънчевият компас има нужда от пет лещи." }
      ]
    },
    {
      "id": "talk-to-lina-before-basket",
      "priority": 5,
      "event": { "type": "npc.talked", "target": "lina" },
      "condition": { "not": { "fact": "lina.helped", "equals": true } },
      "actions": [
        { "type": "fact.set", "fact": "lina.asked_for_basket", "value": true },
        { "type": "dialog.show", "speaker": "Lina", "text": "Where is my basket?", "bg": "Къде е моята кошница?" }
      ]
    },
    {
      "id": "talk-to-lina-after-basket",
      "priority": 10,
      "event": { "type": "npc.talked", "target": "lina" },
      "condition": { "fact": "lina.helped", "equals": true },
      "actions": [
        { "type": "dialog.show", "speaker": "Lina", "text": "The Green Lens is under the flower pot.", "bg": "Зелената леща е под саксията." }
      ]
    },
    {
      "id": "talk-to-lina-after-green-lens",
      "priority": 15,
      "event": { "type": "npc.talked", "target": "lina" },
      "condition": { "fact": "compass.green_lens_placed", "equals": true },
      "stop_propagation": true,
      "actions": [
        { "type": "dialog.show", "speaker": "Lina", "text": "The hut has a jar. A jar can hold light.", "bg": "В колибата има буркан. Бурканът може да държи светлина." }
      ]
    },
    {
      "id": "give-basket-to-lina",
      "once": true,
      "event": { "type": "inventory.item_given_to_npc", "target": "lina" },
      "condition": {
        "all": [
          { "event": "item", "equals": "lost_basket" },
          { "inventory_contains": "lost_basket" }
        ]
      },
      "actions": [
        { "type": "inventory.remove", "item": "lost_basket" },
        { "type": "fact.set", "fact": "lina.helped", "value": true },
        { "type": "dialog.show", "speaker": "Lina", "text": "My seeds are here. Thank you.", "bg": "Семената ми са тук. Благодаря." },
        { "type": "screen.refresh" }
      ]
    },
    {
      "id": "inspect-flower-pot-before-hint",
      "priority": 5,
      "event": { "type": "hotspot.inspected", "target": "flower_pot" },
      "condition": { "not": { "fact": "lina.helped", "equals": true } },
      "stop_propagation": true,
      "actions": [
        { "type": "dialog.show", "speaker": "Alex", "text": "There are flowers here.", "bg": "Тук има цветя." }
      ]
    },
    {
      "id": "inspect-flower-pot-after-hint",
      "priority": 10,
      "once": true,
      "event": { "type": "hotspot.inspected", "target": "flower_pot" },
      "condition": { "fact": "lina.helped", "equals": true },
      "actions": [
        { "type": "fact.set", "fact": "village.flower_pot_checked", "value": true },
        { "type": "dialog.show", "speaker": "Alex", "text": "The Green Lens is here.", "bg": "Зелената леща е тук." },
        { "type": "screen.refresh" }
      ]
    },
    {
      "id": "take-green-lens",
      "once": true,
      "event": { "type": "item.taken", "target": "green_lens" },
      "condition": { "fact": "village.flower_pot_checked", "equals": true },
      "actions": [
        { "type": "inventory.add", "item": "green_lens" },
        { "type": "fact.set", "fact": "item.green_lens.taken", "value": true },
        { "type": "dialog.show", "speaker": "Alex", "text": "I have the Green Lens.", "bg": "Имам Зелената леща." },
        { "type": "screen.refresh" }
      ]
    },
    {
      "id": "place-green-lens",
      "once": true,
      "event": { "type": "inventory.item_used_on_hotspot", "target": "sun_compass" },
      "condition": {
        "all": [
          { "event": "item", "equals": "green_lens" },
          { "inventory_contains": "green_lens" }
        ]
      },
      "actions": [
        { "type": "inventory.remove", "item": "green_lens" },
        { "type": "fact.set", "fact": "compass.green_lens_placed", "value": true },
        { "type": "fact.set", "fact": "location.waterfall_cave.revealed", "value": true },
        { "type": "fact.set", "fact": "slice.green_lens_complete", "value": true },
        { "type": "puzzle.complete", "puzzle": "sun_temple_slice_01_complete" },
        { "type": "dialog.show", "speaker": "Mira", "text": "The cave is on the map.", "bg": "Пещерата е на картата." },
        { "type": "screen.refresh" }
      ]
    },
    {
      "id": "exit-village-to-keeper-locked",
      "priority": 5,
      "event": { "type": "exit.reached", "target": "exit_keeper_hut" },
      "condition": { "not": { "fact": "lina.helped", "equals": true } },
      "stop_propagation": true,
      "actions": [
        { "type": "dialog.show", "speaker": "Alex", "text": "I should help Lina first.", "bg": "Първо трябва да помогна на Лина." }
      ]
    },
    {
      "id": "exit-village-to-keeper",
      "priority": 10,
      "event": { "type": "exit.reached", "target": "exit_keeper_hut" },
      "condition": { "fact": "lina.helped", "equals": true },
      "actions": [
        { "type": "fact.set", "fact": "location.keeper_hut.discovered", "value": true },
        { "type": "scene.transition", "scenario": "scenarios/sun-temple-adventure-keeper-hut-content.json" }
      ]
    },
    {
      "id": "take-empty-jar",
      "once": true,
      "event": { "type": "item.taken", "target": "empty_jar" },
      "actions": [
        { "type": "inventory.add", "item": "empty_jar" },
        { "type": "fact.set", "fact": "item.empty_jar.taken", "value": true },
        { "type": "dialog.show", "speaker": "Alex", "text": "This is an empty jar.", "bg": "Това е празен буркан." },
        { "type": "screen.refresh" }
      ]
    },
    {
      "id": "inspect-hut-shelf",
      "event": { "type": "hotspot.inspected", "target": "hut_shelf" },
      "actions": [
        { "type": "dialog.show", "speaker": "Alex", "text": "These are small plants.", "bg": "Това са малки растения." }
      ]
    },
    {
      "id": "take-glow-leaf",
      "once": true,
      "event": { "type": "item.taken", "target": "glow_leaf" },
      "actions": [
        { "type": "inventory.add", "item": "glow_leaf" },
        { "type": "fact.set", "fact": "item.glow_leaf.taken", "value": true },
        { "type": "dialog.show", "speaker": "Alex", "text": "This leaf has light.", "bg": "Този лист има светлина." },
        { "type": "screen.refresh" }
      ]
    },
    {
      "id": "combine-glow-jar",
      "once": true,
      "event": { "type": "inventory.items_combined" },
      "condition": {
        "all": [
          { "event": "items.0", "equals": "empty_jar" },
          { "event": "items.1", "equals": "glow_leaf" },
          { "inventory_contains": "empty_jar" },
          { "inventory_contains": "glow_leaf" }
        ]
      },
      "actions": [
        { "type": "inventory.remove", "item": "empty_jar" },
        { "type": "inventory.remove", "item": "glow_leaf" },
        { "type": "inventory.add", "item": "glow_jar" },
        { "type": "fact.set", "fact": "craft.glow_jar_made", "value": true },
        { "type": "dialog.show", "speaker": "Alex", "text": "The jar holds the light.", "bg": "Бурканът държи светлината." },
        { "type": "screen.refresh" }
      ]
    },
    {
      "id": "inspect-dark-cave-before-light",
      "priority": 5,
      "event": { "type": "hotspot.inspected", "target": "dark_cave_entrance" },
      "condition": { "not": { "fact": "waterfall.cave_lit", "equals": true } },
      "actions": [
        { "type": "dialog.show", "speaker": "Alex", "text": "The cave is dark. I need light.", "bg": "Пещерата е тъмна. Трябва ми светлина." }
      ]
    },
    {
      "id": "light-dark-cave",
      "once": true,
      "event": { "type": "inventory.item_used_on_hotspot", "target": "dark_cave_entrance" },
      "condition": {
        "all": [
          { "event": "item", "equals": "glow_jar" },
          { "inventory_contains": "glow_jar" }
        ]
      },
      "actions": [
        { "type": "fact.set", "fact": "waterfall.cave_lit", "value": true },
        { "type": "fact.set", "fact": "location.dark_cave.discovered", "value": true },
        { "type": "dialog.show", "speaker": "Alex", "text": "I can see now.", "bg": "Вече виждам." },
        { "type": "screen.refresh" }
      ]
    },
    {
      "id": "inspect-cave-wall",
      "once": true,
      "event": { "type": "hotspot.inspected", "target": "cave_wall" },
      "actions": [
        { "type": "fact.set", "fact": "dark_cave.wall_checked", "value": true },
        { "type": "dialog.show", "speaker": "Alex", "text": "There is a key in the wall.", "bg": "Има ключ в стената." },
        { "type": "screen.refresh" }
      ]
    },
    {
      "id": "take-stone-key",
      "once": true,
      "event": { "type": "item.taken", "target": "stone_key" },
      "condition": { "fact": "dark_cave.wall_checked", "equals": true },
      "actions": [
        { "type": "inventory.add", "item": "stone_key" },
        { "type": "fact.set", "fact": "item.stone_key.taken", "value": true },
        { "type": "dialog.show", "speaker": "Alex", "text": "I have a stone key.", "bg": "Имам каменен ключ." },
        { "type": "screen.refresh" }
      ]
    },
    {
      "id": "inspect-blue-stone-box",
      "priority": 5,
      "event": { "type": "hotspot.inspected", "target": "blue_stone_box" },
      "condition": { "not": { "fact": "dark_cave.box_open", "equals": true } },
      "actions": [
        { "type": "dialog.show", "speaker": "Alex", "text": "The box is closed.", "bg": "Кутията е затворена." }
      ]
    },
    {
      "id": "open-blue-stone-box",
      "once": true,
      "event": { "type": "inventory.item_used_on_hotspot", "target": "blue_stone_box" },
      "condition": {
        "all": [
          { "event": "item", "equals": "stone_key" },
          { "inventory_contains": "stone_key" }
        ]
      },
      "actions": [
        { "type": "inventory.remove", "item": "stone_key" },
        { "type": "fact.set", "fact": "dark_cave.box_open", "value": true },
        { "type": "dialog.show", "speaker": "Alex", "text": "The box is open.", "bg": "Кутията е отворена." },
        { "type": "screen.refresh" }
      ]
    },
    {
      "id": "take-blue-lens",
      "once": true,
      "event": { "type": "item.taken", "target": "blue_lens" },
      "condition": { "fact": "dark_cave.box_open", "equals": true },
      "actions": [
        { "type": "inventory.add", "item": "blue_lens" },
        { "type": "fact.set", "fact": "item.blue_lens.taken", "value": true },
        { "type": "dialog.show", "speaker": "Alex", "text": "I have the Blue Lens.", "bg": "Имам Синята леща." },
        { "type": "screen.refresh" }
      ]
    },
    {
      "id": "place-blue-lens",
      "once": true,
      "event": { "type": "inventory.item_used_on_hotspot", "target": "sun_compass" },
      "condition": {
        "all": [
          { "event": "item", "equals": "blue_lens" },
          { "inventory_contains": "blue_lens" }
        ]
      },
      "actions": [
        { "type": "inventory.remove", "item": "blue_lens" },
        { "type": "fact.set", "fact": "compass.blue_lens_placed", "value": true },
        { "type": "fact.set", "fact": "location.temple_steps.revealed", "value": true },
        { "type": "fact.set", "fact": "slice.blue_lens_complete", "value": true },
        { "type": "puzzle.complete", "puzzle": "sun_temple_slice_02_complete" },
        { "type": "dialog.show", "speaker": "Mira", "text": "The temple steps are on the map.", "bg": "Стъпалата към храма са на картата." },
        { "type": "screen.refresh" }
      ]
    },
    {
      "id": "exit-supply-to-base",
      "event": { "type": "exit.reached", "target": "exit_base_camp" },
      "actions": [
        { "type": "scene.transition", "scenario": "scenarios/sun-temple-adventure-base-camp-table-content.json" }
      ]
    },
    {
      "id": "exit-base-to-supply",
      "event": { "type": "exit.reached", "target": "exit_supply_tent" },
      "actions": [
        { "type": "scene.transition", "scenario": "scenarios/sun-temple-adventure-camp-supply-tent-content.json" }
      ]
    },
    {
      "id": "exit-base-to-edge",
      "event": { "type": "exit.reached", "target": "exit_camp_edge" },
      "actions": [
        { "type": "scene.transition", "scenario": "scenarios/sun-temple-adventure-camp-edge-content.json" }
      ]
    },
    {
      "id": "exit-edge-to-jungle-locked",
      "priority": 5,
      "event": { "type": "exit.reached", "target": "exit_jungle_path" },
      "condition": { "not": { "fact": "map.valley_map_made", "equals": true } },
      "stop_propagation": true,
      "actions": [
        { "type": "dialog.show", "speaker": "Alex", "text": "I need the map.", "bg": "Трябва ми картата." }
      ]
    },
    {
      "id": "exit-edge-to-jungle",
      "priority": 10,
      "event": { "type": "exit.reached", "target": "exit_jungle_path" },
      "condition": { "fact": "map.valley_map_made", "equals": true },
      "actions": [
        { "type": "scene.transition", "scenario": "scenarios/sun-temple-adventure-jungle-path-content.json" }
      ]
    },
    {
      "id": "exit-jungle-to-edge",
      "event": { "type": "exit.reached", "target": "exit_camp_edge" },
      "actions": [
        { "type": "scene.transition", "scenario": "scenarios/sun-temple-adventure-camp-edge-content.json" }
      ]
    },
    {
      "id": "exit-jungle-to-bridge",
      "event": { "type": "exit.reached", "target": "exit_broken_bridge" },
      "actions": [
        { "type": "fact.set", "fact": "location.broken_bridge.discovered", "value": true },
        { "type": "scene.transition", "scenario": "scenarios/sun-temple-adventure-broken-bridge-content.json" }
      ]
    },
    {
      "id": "exit-bridge-to-jungle",
      "event": { "type": "exit.reached", "target": "exit_jungle_path" },
      "actions": [
        { "type": "scene.transition", "scenario": "scenarios/sun-temple-adventure-jungle-path-content.json" }
      ]
    },
    {
      "id": "exit-bridge-to-village-locked",
      "priority": 5,
      "event": { "type": "exit.reached", "target": "exit_village_garden" },
      "condition": { "not": { "fact": "bridge.repaired", "equals": true } },
