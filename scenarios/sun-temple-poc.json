  "dialogues": {
    "guide_intro_tree": {
      "start_node": "node_1",
      "nodes": {
        "node_1": {
          "speaker": "Guide",
          "npc_text": "Good work, Alex. Look at me now. What am I doing?",
          "npc_text_bg": "Добра работа, Алекс. Погледни ме сега. Какво правя?",
          "options": [
            {
              "text": "You look at the map.",
              "is_correct": false,
              "feedback_bg": "Това звучи като навик. Когато действието се случва точно сега, използваме am/is/are + -ing."
            },
            {
              "text": "You are looking at the map.",
              "is_correct": true,
              "next_node": "node_2"
            },
            {
              "text": "You looking at the map.",
              "is_correct": false,
              "feedback_bg": "Липсва помощният глагол are. Правилната форма е: You are looking."
            }
          ]
        },
        "node_2": {
          "speaker": "Guide",
          "npc_text": "Exactly. The jungle path is open. Stay sharp, explorer.",
          "npc_text_bg": "Точно така. Пътеката към джунглата е отворена. Бъди нащрек, изследователю.",
          "options": [
            {
              "text": "To the jungle!",
              "is_correct": true,
              "action": { "type": "set_flag", "flag": "jungle_path_open" }
            }
          ]
        }
      }
    },
    "panther_tree": {
      "start_node": "node_1",
      "nodes": {
        "node_1": {
          "speaker": "Guide",
          "npc_text": "Read the clue: The panther sleeps during the day. Which sentence talks about its habit?",
          "npc_text_bg": "Прочети подсказката: Пантерата спи през деня. Кое изречение говори за нейния навик?",
          "options": [
            {
              "text": "The panther is sleeping during the day.",
              "is_correct": false,
              "feedback_bg": "Това описва действие точно сега. За навици и факти използваме Present Simple: sleeps."
            },
            {
              "text": "The panther sleeps during the day.",
              "is_correct": true,
              "next_node": "node_2"
            },
            {
              "text": "The panther sleep during the day.",
              "is_correct": false,
              "feedback_bg": "При he/she/it в Present Simple добавяме -s: the panther sleeps."
            }
          ]
        },
        "node_2": {
          "speaker": "Guide",
          "npc_text": "Right. It sleeps now, so we can sneak past quietly.",
          "npc_text_bg": "Правилно. Сега тя спи, затова можем тихо да се промъкнем покрай нея.",
          "options": [
            {
              "text": "Sneak past",
              "is_correct": true,
              "action": { "type": "set_flag", "flag": "panther_path_clear" }
            }
          ]
        }
      }
    },
    "sun_symbol_tree": {
      "start_node": "node_1",
      "nodes": {
        "node_1": {
          "speaker": "Alex",
          "npc_text": "The carving shows a sun above the gate. Which phrase is correct?",
          "npc_text_bg": "Резбата показва слънце над портата. Кой израз е правилен?",
          "options": [
            {
              "text": "the suns door",
              "is_correct": false,
              "feedback_bg": "Когато казваме, че вратата принадлежи на слънцето, използваме possessive 's: the sun's door."
            },
            {
              "text": "the sun's door",
              "is_correct": true,
              "action": { "type": "set_flag", "flag": "sun_symbol_read" }
            }
          ]
        }
      }
    }
